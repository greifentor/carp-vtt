<?xml version="1.1" encoding="UTF-8" standalone="no"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog" xmlns:ext="http://www.liquibase.org/xml/ns/dbchangelog-ext" xmlns:pro="http://www.liquibase.org/xml/ns/pro" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog-ext http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-ext.xsd http://www.liquibase.org/xml/ns/pro http://www.liquibase.org/xml/ns/pro/liquibase-pro-4.6.xsd http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.6.xsd">
    <changeSet author="dm-comp" id="Initial-Tables" objectQuotingStrategy="LEGACY" runOnChange="true">
        <createTable tableName="TOKEN">
            <column name="IMAGE" type="LONGVARBINARY">
                <constraints nullable="false"/>
            </column>
            <column name="ID" type="VARCHAR(40)">
                <constraints nullable="false"/>
            </column>
            <column name="NAME" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <addPrimaryKey columnNames="ID" tableName="TOKEN"/>
    </changeSet>
    <changeSet author="dm-comp" id="Added-Table-MAP" runInTransaction="true" runOnChange="true">
        <createTable tableName="MAP">
            <column name="IMAGE" type="LONGVARBINARY">
                <constraints nullable="false"/>
            </column>
            <column name="ID" type="VARCHAR(40)">
                <constraints nullable="false"/>
            </column>
            <column name="NAME" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <addPrimaryKey columnNames="ID" tableName="MAP"/>
    </changeSet>
    <changeSet author="dm-comp" id="Added-Field-TOKEN_SIZE-to-Table-TOKEN" runInTransaction="true" runOnChange="true">
        <addColumn tableName="TOKEN">
            <column name="TOKEN_SIZE" type="VARCHAR(20)" defaultValue="MEDIUM">
                <constraints nullable="false"/>
            </column>
        </addColumn>
    </changeSet>
    <changeSet author="dm-comp" id="Add-Table-PARTY" objectQuotingStrategy="LEGACY" runOnChange="true">
        <createTable tableName="PARTY">
            <column name="ID" type="VARCHAR(40)">
                <constraints nullable="false"/>
            </column>
            <column name="NAME" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <addPrimaryKey columnNames="ID" tableName="PARTY"/>
    </changeSet>
    <changeSet author="dm-comp" id="Add-Table-SCENARIO" objectQuotingStrategy="LEGACY" runOnChange="true">
        <createTable tableName="SCENARIO">
            <column name="ID" type="VARCHAR(40)">
                <constraints nullable="false"/>
            </column>
            <column name="NAME" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <addPrimaryKey columnNames="ID" tableName="SCENARIO"/>
    </changeSet>
    <changeSet author="dm-comp" id="Changed-Datatype-for-ID-Fields-of-Table-PARTY-and-SCENARIO" runInTransaction="true" runOnChange="true">
        <modifyDataType tableName="PARTY" columnName="ID" newDataType="UUID"/>
        <modifyDataType tableName="SCENARIO" columnName="ID" newDataType="UUID"/>
    </changeSet>
    <changeSet author="dm-comp" id="Changed-Datatype-for-ID-Fields-of-Table-MAP-and-TOKEN" runInTransaction="true" runOnChange="true">
        <modifyDataType tableName="MAP" columnName="ID" newDataType="UUID"/>
        <modifyDataType tableName="TOKEN" columnName="ID" newDataType="UUID"/>
    </changeSet>
    <changeSet id="Add-Table-TOKEN_MAP_PARTY_SCENARIO" author="copilot" objectQuotingStrategy="LEGACY" runOnChange="true">
        <createTable tableName="TOKEN_MAP_PARTY_SCENARIO">
            <column name="ID" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="MAP_ID" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="TOKEN_ID" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="PARTY_ID" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="SCENARIO_ID" type="UUID">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <addForeignKeyConstraint
                baseTableName="TOKEN_MAP_PARTY_SCENARIO"
                baseColumnNames="MAP_ID"
                referencedTableName="MAP"
                referencedColumnNames="ID"
                constraintName="FK_TMP_S_MAP"/>
        <addForeignKeyConstraint
                baseTableName="TOKEN_MAP_PARTY_SCENARIO"
                baseColumnNames="TOKEN_ID"
                referencedTableName="TOKEN"
                referencedColumnNames="ID"
                constraintName="FK_TMP_S_TOKEN"/>
        <addForeignKeyConstraint
                baseTableName="TOKEN_MAP_PARTY_SCENARIO"
                baseColumnNames="PARTY_ID"
                referencedTableName="PARTY"
                referencedColumnNames="ID"
                constraintName="FK_TMP_S_PARTY"/>
        <addForeignKeyConstraint
                baseTableName="TOKEN_MAP_PARTY_SCENARIO"
                baseColumnNames="SCENARIO_ID"
                referencedTableName="SCENARIO"
                referencedColumnNames="ID"
                constraintName="FK_TMP_S_SCENARIO"/>
        <addUniqueConstraint
                tableName="TOKEN_MAP_PARTY_SCENARIO"
                columnNames="MAP_ID, TOKEN_ID, PARTY_ID, SCENARIO_ID"
                constraintName="UC_TOKEN_MAP_PARTY_SCENARIO_ALL"/>
    </changeSet>
    <changeSet author="dm-comp" id="Added-Fields-FIELD_X-and-FIELD_Y-to-table-TOKEN_MAP_PARTY_SCENARIO" runInTransaction="true" runOnChange="true">
        <addColumn tableName="TOKEN_MAP_PARTY_SCENARIO">
            <column name="FIELD_X" type="NUMERIC(6,2)" defaultValue="0.0">
                <constraints nullable="false"/>
            </column>
        </addColumn>
        <addColumn tableName="TOKEN_MAP_PARTY_SCENARIO">
            <column name="FIELD_Y" type="NUMERIC(6,2)" defaultValue="0.0">
                <constraints nullable="false"/>
            </column>
        </addColumn>
    </changeSet>
    <changeSet author="dm-comp" id="Added-Dummy-Party" runInTransaction="true" runOnChange="true">
        <insert tableName="PARTY">
            <column name="ID" value="d95b7312-5669-4ee5-9299-4516034f46d8"/>
            <column name="NAME" value="Dummy-Party"/>
        </insert>
    </changeSet>
    <changeSet author="dm-comp" id="Added-Dummy-Scenario" runInTransaction="true" runOnChange="true">
        <insert tableName="SCENARIO">
            <column name="ID" value="d95b7312-5669-4ee5-9299-4516034f46d8"/>
            <column name="NAME" value="Dummy-Scenario"/>
        </insert>
    </changeSet>
    <changeSet author="dm-comp" id="Corrected-Dummy-Scenario" runInTransaction="true" runOnChange="true">
        <delete tableName="SCENARIO">
            <where>ID = 'd95b7312-5669-4ee5-9299-4516034f46d8'</where>
        </delete>
        <insert tableName="SCENARIO">
            <column name="ID" value="60d8b44d-f60f-4b04-b9bb-133b3335db0f"/>
            <column name="NAME" value="Dummy-Scenario"/>
        </insert>
    </changeSet>
    <changeSet id="Re-Add-Table-TOKEN_MAP_PARTY_SCENARIO" author="copilot" objectQuotingStrategy="LEGACY" runOnChange="true">
        <addForeignKeyConstraint
                baseTableName="TOKEN_MAP_PARTY_SCENARIO"
                baseColumnNames="MAP_ID"
                referencedTableName="MAP"
                referencedColumnNames="ID"
                constraintName="FK_TOKEN_MAP_PARTY_SCENARIO_TO_MAP"/>
        <addForeignKeyConstraint
                baseTableName="TOKEN_MAP_PARTY_SCENARIO"
                baseColumnNames="TOKEN_ID"
                referencedTableName="TOKEN"
                referencedColumnNames="ID"
                constraintName="FK_TOKEN_MAP_PARTY_SCENARIO_TO_TOKEN"/>
        <addForeignKeyConstraint
                baseTableName="TOKEN_MAP_PARTY_SCENARIO"
                baseColumnNames="PARTY_ID"
                referencedTableName="PARTY"
                referencedColumnNames="ID"
                constraintName="FK_TOKEN_MAP_PARTY_SCENARIO_TO_PARTY"/>
        <addForeignKeyConstraint
                baseTableName="TOKEN_MAP_PARTY_SCENARIO"
                baseColumnNames="SCENARIO_ID"
                referencedTableName="SCENARIO"
                referencedColumnNames="ID"
                constraintName="FK_TOKEN_MAP_PARTY_SCENARIO_TO_SCENARIO"/>
    </changeSet>
</databaseChangeLog>